DATABASE_URL=postgresql://user:password@host:5432/database
FRONTEND_URL=http://localhost:5173
PUBLIC_BACKEND_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:5173

# Iyzico sandbox bilgileriyle başlayın; canlıya geçerken base URL'i değiştirin.
IYZICO_API_KEY=your_iyzico_api_key
IYZICO_SECRET_KEY=your_iyzico_secret_key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
IYZICO_CALLBACK_URL=http://localhost:8000/api/payments/iyzico/callback

# Opsiyonel: AI metin üretimi için OpenRouter uyumlu anahtar.
AI_API_KEY=your_ai_api_key

# Telegram /start komutu ile siteyi tekrar müşteri paneline almak için.
# Bot token'ı frontend'e koymayın; Telegram webhook URL'inde ayrı bir secret kullanın.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=choose-a-long-random-secret
TELEGRAM_ADMIN_CHAT_ID=your_telegram_chat_id

# Lokal dosya yükleme klasörü. Vercel/serverless için kalıcı object storage önerilir.
UPLOAD_DIR=uploads
