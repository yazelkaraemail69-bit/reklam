# === Admin Panel Kimlik Dogrulama (ZORUNLU - production'da mutlaka degistirin) ===
# Admin paneline giris sifresi.
ADMIN_PASSWORD=degistir-bu-sifreyi-123

# Oturum cerezini imzalamak icin kullanilan gizli anahtar (rastgele, uzun bir metin).
# Uretmek icin: openssl rand -hex 32
SESSION_SECRET=degistir-bu-anahtari-cok-uzun-ve-rastgele-yap

# === Kalici Veri Deposu (OPSIYONEL ama production icin ONERILIR) ===
# Vercel Dashboard > Storage > "Create Database" > Upstash for Redis secince
# bu iki degisken projenize otomatik eklenir (tek tikla). Tanimlanmazsa uygulama
# yerel data/*.json dosyasi ile calisir; bu Vercel'de salt-okunurdur, admin
# panelinden yapilan degisiklikler kalici olmaz (demo modu).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === Gorsel Yukleme (OPSIYONEL ama production icin ONERILIR) ===
# Vercel Dashboard > Storage > "Create Database" > Blob secince bu degisken
# projenize otomatik eklenir (tek tikla). Tanimlanmazsa yuklenen gorseller
# yerel public/uploads klasorune yazilir; bu Vercel'de salt-okunurdur, yani
# admin panelinden yuklenen gorseller kalici olmaz (demo modu).
BLOB_READ_WRITE_TOKEN=

# === Site Ayarlari ===
# Canli domain adresiniz (SEO/OG etiketleri icin kullanilir).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Kardes Urun Tanitimi (OPSIYONEL) ===
# Reklamini verdigimiz isletmelere vitrin sayfalarinda onerilen, ayri bir
# Next.js projesi olan Dijital Kartvizit + Menu + AI Shorts video araci
# (bkz. dijital-kartvizit-menu/ klasoru). Bu araci deploy ettiginizde gercek
# adresini buraya yazin; bos birakilirsa yerel gelistirme icin
# http://localhost:3001 varsayilir (bkz. lib/constants.ts).
NEXT_PUBLIC_TOOLS_SITE_URL=

# === Iyzico Linkle Odeme (Pay by Link) ===
# Sandbox anahtarlarinizi Iyzico merchant panelinden alin.
# Canliya geciste IYZICO_SANDBOX=false yapin ve production anahtarlarini kullanin.
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_SANDBOX=true
# Opsiyonel: varsayilan sandbox/live URL'lerini ezmek icin
# IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# Webhook imza yoksa bile kabul et (yalnizca gecici / gelistirme)
# IYZICO_WEBHOOK_RELAXED=true

# === E-posta (SMTP) ===
# Production'da gercek SMTP doldurun. Gelistirmede SMTP yoksa e-posta konsola yazilir.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Reklam Vitrini <bildirim@siteniz.com>"
# SMTP_SECURE=false
# Zorunlu mock (konsola yaz): SMTP_MOCK=true

# === SIFIR MALİYETLİ ÜCRETSİZ API ENTEGRASYONLARI ===
# 1. Google Gemini AI (Ücretsiz Metin & Reklam Üretimi - Google AI Studio)
GEMINI_API_KEY=

# 2. Telegram Bot Bildirimleri (Sınırsız & %100 Ücretsiz SMS Alternatifi)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 3. Unsplash Stok Görsel API (Ücretsiz Fotoğraf Motoru)
UNSPLASH_ACCESS_KEY=

# 4. Resend E-posta Bildirimi (Aylık 3.000 Ücretsiz E-posta)
RESEND_API_KEY=


